<Application x:Class="Projekt_prog.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Projekt_prog"
             xmlns:viewModel="clr-namespace:Projekt_prog.WMW.ModeleWidokow"
             xmlns:view="clr-namespace:Projekt_prog.WMW.Widoki"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Motywy/TextBoxWyszukiwarka.xaml"/>
                <ResourceDictionary Source="Motywy/Przyciski.xaml"/>
                <ResourceDictionary Source="Motywy/MotywCiemny.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModel:DoObejrzeniaViewModel}">
                <view:HomeView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:ObejrzaneViewModel}">
                <view:ObejrzaneView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:UstawieniaViewModel}">
                <view:UstawieniaView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
