<Window x:Class="Projekt_prog.Edytuj"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_prog"
        mc:Ignorable="d"
        Title="Edytuj" Height="400" Width="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Border x:Name="EditBorder" BorderBrush="Black" BorderThickness="2" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- title -->
            <TextBlock Text="Edytuj film"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="20,0,0,0"
                       Foreground="#8D4004"
                       FontSize="25"
                       FontWeight="ExtraBold"/>

            <!-- close button  -->
            <Button Content="✕"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,15,0"
                    Width="30" Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#8D4004"
                    FontSize="16"
                    Cursor="Hand" Click="Button_Click"/>

            <!-- form -->
            <Grid Grid.Row="1" Margin="30,15,30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- movie title -->
                <TextBlock Text="Tytuł:"
                           Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#2B2B2B"
                           FontSize="14" FontWeight="SemiBold"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         Background="#353340"
                         Foreground="#CFCFCF"
                         CaretBrush="#CFCFCF"
                         BorderThickness="0"
                         FontSize="13"
                         Text="{Binding Tytul, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- genre -->
                <TextBlock Text="Gatunek:"
                           Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#2B2B2B"
                           FontSize="14" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          Height="35"
                          Background="#353340"
                          Foreground="#353340"
                          BorderThickness="0"
                          FontSize="13"
                          SelectedItem="{Binding Gatunek}">
                    <ComboBoxItem>Akcja</ComboBoxItem>
                    <ComboBoxItem>Komedia</ComboBoxItem>
                    <ComboBoxItem>Dramat</ComboBoxItem>
                    <ComboBoxItem>Horror</ComboBoxItem>
                    <ComboBoxItem>Sci-Fi</ComboBoxItem>
                    <ComboBoxItem>Romans</ComboBoxItem>
                    <ComboBoxItem>Animacja</ComboBoxItem>
                    <ComboBoxItem>Dokumentalny</ComboBoxItem>
                    <ComboBoxItem>Thriller</ComboBoxItem>
                    <ComboBoxItem>Fantasy</ComboBoxItem>
                </ComboBox>

                <!-- year -->
                <TextBlock Text="Rok produkcji:"
                           Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#2B2B2B"
                           FontSize="14" FontWeight="SemiBold"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Height="35"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         Background="#353340"
                         Foreground="#CFCFCF"
                         CaretBrush="#CFCFCF"
                         BorderThickness="0"
                         FontSize="13"
                         Text="{Binding Rok, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- rating -->
                <TextBlock Text="Ocena:"
                           Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#2B2B2B"
                           FontSize="14" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="3" Grid.Column="1"
                          Height="35"
                          Background="#353340"
                          Foreground="#353340"
                          BorderThickness="0"
                          FontSize="13"
                          SelectedItem="{Binding Ocena}">
                    <ComboBoxItem>⭐ 1 - Słaby</ComboBoxItem>
                    <ComboBoxItem>⭐⭐ 2 - Przeciętny</ComboBoxItem>
                    <ComboBoxItem>⭐⭐⭐ 3 - Dobry</ComboBoxItem>
                    <ComboBoxItem>⭐⭐⭐⭐ 4 - Bardzo dobry</ComboBoxItem>
                    <ComboBoxItem>⭐⭐⭐⭐⭐ 5 - Doskonały</ComboBoxItem>
                </ComboBox>

                <!-- stats -->
                <TextBlock Text="Status:"
                           Grid.Row="4" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#2B2B2B"
                           FontSize="14" FontWeight="SemiBold"/>
                <ComboBox Grid.Row="4" Grid.Column="1"
                          Height="35"
                          Background="#353340"
                          Foreground="#353340"
                          BorderThickness="0"
                          FontSize="13"
                          SelectedItem="{Binding Status}">
                    <ComboBoxItem>Obejrzany</ComboBoxItem>
                    <ComboBoxItem>Do obejrzenia</ComboBoxItem>
                </ComboBox>

                <!-- save/close buttons -->
                <StackPanel Grid.Row="5" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button Content="Zapisz zmiany"
                            Width="120" Height="38"
                            Margin="0,0,10,0"
                            Cursor="Hand"
                            Command="{Binding ZapiszCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#8D4004"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#A84E05"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Anuluj"
                            Width="100" Height="38"
                            Cursor="Hand" Click="Button_Click_1">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#353340"/>
                                <Setter Property="Foreground" Value="#CFCFCF"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4A4760"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>