<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ButtonBrush"        Color="#3D2410"/>
    <!-- Tekst główny -->
    <SolidColorBrush x:Key="TextBrush"          Color="#F0C89A"/>
    <!-- Tekst drugorzędny -->
    <SolidColorBrush x:Key="SubTextBrush"       Color="#C49060"/>
    <!-- Hover menu bocznego -->
    <SolidColorBrush x:Key="MenuHoverBrush"     Color="#5C3520"/>
</ResourceDictionary>