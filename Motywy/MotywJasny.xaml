<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ButtonBrush"        Color="#FFFFFF"/>
    <!-- Tekst główny -->
    <SolidColorBrush x:Key="TextBrush"          Color="#8D4004"/>
    <!-- Tekst drugorzędny -->
    <SolidColorBrush x:Key="SubTextBrush"       Color="#A0522D"/>
    <!-- Hover menu bocznego -->
    <SolidColorBrush x:Key="MenuHoverBrush"     Color="#E8C9A0"/>
</ResourceDictionary>